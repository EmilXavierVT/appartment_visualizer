{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Apartment Visualizer",
  "version": "0.1.0",
  "identifier": "dk.projectice.apartmentvisualizer",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Lifestyle",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
